# Release signing credentials — TEMPLATE.
#
# Copy this file to `keystore.properties` (same directory, repo root) and fill in your values.
# `keystore.properties` is gitignored and must NEVER be committed.
#
# When this file is absent the project still builds; the release build is just unsigned.
# Once present, `./gradlew :app:bundleRelease` / `:app:assembleRelease` produce a signed artifact.
#
# To create a keystore (once):
#   keytool -genkey -v -keystore pdfmaster-release.jks -keyalg RSA -keysize 2048 \
#           -validity 10000 -alias pdfmaster
#
# storeFile is resolved relative to the repo root (or use an absolute path). Keep the .jks
# OUTSIDE version control too (*.jks is gitignored).

storeFile=pdfmaster-release.jks
storePassword=CHANGE_ME
keyAlias=pdfmaster
keyPassword=CHANGE_ME
